# Data — never commit raw or processed data, only schema docs
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Models — saved artifacts
*.joblib
*.pkl
*.pickle

# Reports — keep source, ignore build artifacts
reports/*.pdf
reports/*.aux
reports/*.log
reports/*.out
reports/*.bbl
reports/*.blg
reports/*.synctex.gz

# Secrets
.env
.env.*
!.env.example
secrets/
*.key

# OS
Thumbs.db
